{
  "name": "gymbo",
  "version": "2.0.0",
  "description": "GymBo — Telegram Mini App fitness tracker with AI coach",
  "private": true,
  "scripts": {
    "build": "nest build && tsc-alias && vite build",
    "build:back": "nest build && tsc-alias",
    "build:front": "vite build",
    "watch:front": "vite build --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "dev": "concurrently --kill-others-on-fail -n back,front -c blue,magenta \"npm run start:dev\" \"npm run watch:front\"",
    "start:prod": "node dist/main",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/terminus": "^11.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.0.0",
    "multer": "^1.4.5-lts.2",
    "nestjs-pino": "^4.6.1",
    "nestjs-telegraf": "^2.8.0",
    "node-cron": "^4.0.0",
    "openai": "^4.80.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "sequelize": "^6.37.0",
    "sequelize-cli": "^6.6.0",
    "sequelize-typescript": "^2.1.0",
    "telegraf": "^4.16.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.7.0",
    "vite": "^8.0.9"
  }
}
