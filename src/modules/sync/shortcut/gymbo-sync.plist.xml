<?xml version="1.0" encoding="UTF-8"?>
<!--
  GymBo Apple Health sync — iOS Shortcut template.

  This file is served (with per-user token substituted) via
  GET /api/sync/apple-health/shortcut?t=<token>. iOS Shortcuts.app
  accepts XML plists directly on import, so we patch the two
  placeholders at request time and hand the bytes over.

  Placeholders (string-level, substituted server-side):
    __INGEST_URL__ — POST target, e.g.
                     https://gymbo-prod.herokuapp.com/api/sync/apple-health/ingest
    __TOKEN__      — long-lived bearer that the athlete's connect
                     call returned (SyncConnections.token).

  REAL TEMPLATE TO USE:
    Build a full HealthKit-aware Shortcut in Shortcuts.app (actions:
    Find Health Samples for Body Mass, Sleep, Resting HR, HRV,
    Active Energy, Steps + Find Workouts + build a Dictionary and
    POST via Get Contents of URL), export it, then run
      plutil -convert xml1 gymbo-sync.shortcut -o new-template.xml
    and replace the XML below with the result. Keep the two
    placeholders for the URL and the token.

  The stub below is a valid minimal shortcut that performs a single
  POST ping to the ingest URL with "Authorization: Bearer <token>"
  and shows a notification. Enough to verify the install pipeline
  before the dev replaces it with the real HealthKit-heavy version.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
