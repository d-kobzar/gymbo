# App
# development | production | test
NODE_ENV=development
PORT=3000
APP_URL=https://your-domain.example
# debug | info | warn | error — falls back to info in prod, debug otherwise
# LOG_LEVEL=info

# Database
# SSL is enabled automatically when NODE_ENV=production (Heroku Postgres etc.)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gymbo

# Auth
JWT_SECRET=change-me-to-a-long-random-string
# Any ms-style duration string: "30d", "12h", "15m"
# JWT_EXPIRES_IN=30d

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# polling (default) or webhook — webhook requires a public APP_URL
# BOT_MODE=polling

# LLM
OPENAI_API_KEY=
# LLM_PROVIDER=openai        (openai — only provider today; anthropic/gemini/... to come)
# LLM_MODEL=gpt-4o           (any model id your provider accepts)
# LLM_MAX_OUTPUT_TOKENS=2000
# LLM_DEBOUNCE_MS=7000       (how long to wait for user to stop typing before calling the LLM)
# LLM_SUMMARY_REGEN_THRESHOLD=20
# LLM_MESSAGE_GC_DAYS=7      (summarized coach messages are deleted after this many days)

# Backblaze B2 (S3-compatible)
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
